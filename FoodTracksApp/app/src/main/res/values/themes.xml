<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.FoodTracks" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">@color/fondo</item>
        <item name="android:navigationBarColor">@color/fondo</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.FoodTracks" parent="Base.Theme.FoodTracks" />

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize10Percent" parent="">
        <item name="cornerSize">10%</item>
    </style>

    <style name="TemaSwitchPersonalizado" parent="">
        <item name="colorPrimary">@color/secondary</item>
        <item name="colorSecondary">@color/secondary</item>

        <item name="colorControlActivated">@color/secondary</item>
        <item name="colorPrimaryContainer">@color/secondary</item>
    </style>

    <style name="Theme.BottomNavLocal" parent="Theme.FoodTracks">
        <item name="colorSecondaryContainer">@color/black</item>
        <item name="colorOnSecondaryContainer">@color/white</item>
    </style>

    <style name="ThemeOverlay.InputRegistro" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="colorPrimary">@color/tertiary</item>
        <item name="colorControlActivated">@color/tertiary</item>
        <item name="android:textColorHighlight">#4DFFFFFF</item>
    </style>

    <style name="EstiloInputRegistro" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/selector_borde_input</item>

        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>

        <item name="hintTextColor">@color/tertiary</item>

        <item name="android:textColorHint" />

        <item name="materialThemeOverlay">@style/ThemeOverlay.InputRegistro</item>
    </style>
</resources>
