<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- TOP BAR (Barra superior fija tipo Instagram) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBarPerfil"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/fondo"
        android:paddingHorizontal="25dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvUsernameCliente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CÍRCULO DE CARGA (Visible por defecto) -->
    <ProgressBar
        android:id="@+id/progressBarPerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topBarPerfil" />

    <!-- TODO EL CONTENIDO DEL PERFIL (Oculto por defecto con visibility="gone") -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/layoutContenidoPerfil"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topBarPerfil">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <!-- CABECERA DE DATOS (Sin el username) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                android:paddingHorizontal="25dp">

                <!-- Foto de perfil -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgPerfilCliente"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar_default"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

                <!-- Nombre Completo -->
                <TextView
                    android:id="@+id/tvNombreCliente"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/nombre_completo"
                    android:textColor="#E0E0E0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/imgPerfilCliente"
                    app:layout_constraintTop_toTopOf="@+id/imgPerfilCliente" />

                <!-- Ciudad -->
                <TextView
                    android:id="@+id/tvCiudadCliente"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:drawablePadding="8dp"
                    android:text="@string/ciudad"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    app:drawableStartCompat="@drawable/ic_location"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/imgPerfilCliente"
                    app:layout_constraintTop_toBottomOf="@+id/tvNombreCliente" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- SEPARADOR VISUAL -->
            <View
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:layout_marginBottom="20dp"
                android:background="@color/black" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="25dp">
                <!-- INFORMACIÓN ADICIONAL -->
                <TextView
                    android:id="@+id/tvMiembroDesde"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/miembro_desde"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFechaRegistroCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/preferencias_alimenticias"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- PREFERENCIAS -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPreferencias"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:singleSelection="false"></com.google.android.material.chip.ChipGroup>
            </LinearLayout>
            <!-- SEPARADOR VISUAL PARA PUBLICACIONES -->
            <View
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:layout_marginBottom="20dp"
                android:background="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="15dp"
                android:text="@string/publicaciones"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- TEXTO: SIN PUBLICACIONES (Oculto por defecto) -->
            <TextView
                android:id="@+id/tvSinPublicaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:text="@string/no_hay_publicaciones_aun"
                android:textAlignment="center"
                android:textColor="#888888"
                android:textSize="16sp"
                android:textStyle="italic" />

            <!-- LISTA DE PUBLICACIONES -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPublicacionesCliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="25dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
