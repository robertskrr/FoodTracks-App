<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:padding="25dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:orientation="vertical">

        <!-- CABECERA  -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp">

            <!-- Foto de perfil -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgPerfilCliente"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_default"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

            <!-- Nombre -->
            <TextView
                android:id="@+id/tvNombreCliente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="@string/nombre_completo"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imgPerfilCliente"
                app:layout_constraintTop_toTopOf="@+id/imgPerfilCliente" />

            <!-- Username -->
            <TextView
                android:id="@+id/tvUsernameCliente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="4dp"
                android:text="@string/nombre_de_usuario"
                android:textColor="@color/tertiary"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imgPerfilCliente"
                app:layout_constraintTop_toBottomOf="@+id/tvNombreCliente" />

            <!-- Ciudad -->
            <TextView
                android:id="@+id/tvCiudadCliente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:drawablePadding="8dp"
                android:text="@string/ciudad"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                app:drawableStartCompat="@drawable/ic_location"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imgPerfilCliente"
                app:layout_constraintTop_toBottomOf="@+id/tvUsernameCliente" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- SEPARADOR VISUAL -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="20dp"
            android:background="#333333" />

        <!-- INFORMACIÓN ADICIONAL -->
        <TextView
            android:id="@+id/tvMiembroDesde"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/miembro_desde"
            android:textColor="#CCCCCC"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvFechaRegistroCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/preferencias_alimenticias"
            android:textColor="#CCCCCC"
            android:textSize="14sp" />

        <!-- PREFERENCIAS -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupPreferencias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:singleSelection="false">

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>
</ScrollView>