<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_perfil_local"
    android:fitsSystemWindows="true"
    tools:context=".activities.local.RegisterLocalActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="32dp">

            <TextView
                android:id="@+id/textViewTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="sans-serif-condensed-medium"
                android:letterSpacing="0.05"
                android:text="@string/registro_local"
                android:textColor="@color/tertiary"
                android:textSize="30sp" />

            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="24dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgPerfilLocal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/secondary"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar_default"
                    app:contentPadding="2dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                    app:strokeColor="@color/tertiary"
                    app:strokeWidth="3dp" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnSeleccionarFotoLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:contentDescription="@string/cambiar_foto_de_perfil"
                    android:onClick="setGalleryLauncher"
                    app:backgroundTint="@color/white"
                    app:fabSize="mini"
                    app:srcCompat="@android:drawable/ic_menu_camera"
                    app:tint="@color/tertiary"
                    tools:ignore="ClassNameCheck" />
            </FrameLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/nombre_del_establecimiento">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtNombreLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/nombre_de_usuario">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtUsernameLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/correo_electronico">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtEmailLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/contrasenia"
                app:passwordToggleEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtPasswordLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/confirmar_contrasenia"
                app:passwordToggleEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtConfirmPasswordLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/direccion_requerimientos">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtDireccionLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPostalAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/ciudad">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtCiudadLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/telefono">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtTelefonoLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/sitio_web_opcional">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtSitioWebLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="@string/opciones_alimenticias_que_ofrece"
                android:textAlignment="center"
                android:textColor="@color/tertiary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alignmentMode="alignBounds"
                android:columnCount="2"
                android:foregroundGravity="center_horizontal"
                android:rowCount="3">

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbVeganoLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/vegano"
                    android:textColor="@color/white" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbVegetarianoLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/vegetariano"
                    android:textColor="@color/white" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbLactosaLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/sin_lactosa"
                    android:textColor="@color/white" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbCeliacoLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/celiaco"
                    android:textColor="@color/white" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbOtroLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/otro"
                    android:textColor="@color/white" />

                <EditText
                    android:id="@+id/txtEspecifiqueOtroLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="@string/cual"
                    android:inputType="text"
                    android:textColor="@color/white"
                    android:theme="@style/ThemeOverlay.InputRegistro"
                    android:visibility="gone"
                    tools:ignore="Autofill" />
            </GridLayout>

            <Button
                android:id="@+id/btnFinalizarRegistroLocal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/tertiary"
                android:onClick="registroLocal"
                android:text="@string/crear_cuenta"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
