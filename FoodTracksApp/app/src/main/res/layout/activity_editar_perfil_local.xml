<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_perfil_local"
    android:fitsSystemWindows="true">

    <ProgressBar
        android:id="@+id/progressEditarLocal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/layoutEditarLocal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="sans-serif-condensed-medium"
                android:letterSpacing="0.05"
                android:text="@string/editar_perfil"
                android:textColor="@color/tertiary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgEditarFotoLocal"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="10dp"
                android:background="@color/secondary"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_default"
                app:contentPadding="2dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                app:strokeColor="@color/tertiary"
                app:strokeWidth="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/toca_la_imagen_para_cambiarla"
                android:textColor="@color/tertiary"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/nombre_del_establecimiento">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtEditNombreLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/nombre_de_usuario">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtEditUsernameLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/direccion_requerimientos">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtEditDireccionLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPostalAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/ciudad">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtEditCiudadLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/telefono">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtEditTelefonoLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/sitio_web_opcional">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtEditWebLocal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:text="@string/opciones_alimenticias_que_ofrece"
                android:textAlignment="center"
                android:textColor="@color/tertiary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alignmentMode="alignBounds"
                android:columnCount="2"
                android:foregroundGravity="center_horizontal"
                android:rowCount="3">

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbEditVeganoL"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/vegano"
                    android:textColor="@color/white" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbEditVegetarianoL"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/vegetariano"
                    android:textColor="@color/white" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbEditLactosaL"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/sin_lactosa"
                    android:textColor="@color/white" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbEditCeliacoL"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/celiaco"
                    android:textColor="@color/white" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbEditOtroL"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/tertiary"
                    android:text="@string/otro"
                    android:textColor="@color/white" />
            </GridLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutEditEspecifiqueOtroL"
                style="@style/EstiloInputRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtEditEspecifiqueOtroL"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/cual"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnGuardarCambiosLocal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/tertiary"
                android:text="@string/guardar_cambios"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/btnVolverSettingsL"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/cancelar"
                android:textColor="@color/tertiary" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>