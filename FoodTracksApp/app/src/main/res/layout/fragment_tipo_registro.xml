<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#DED9D9"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    app:contentPadding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtTipoRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:fontFamily="sans-serif-black"
            android:text="@string/comes_o_cocinas"
            android:textAlignment="center"
            android:textColor="@color/tertiary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegistroCliente"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary"
                android:text="@string/cliente"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:icon="@drawable/ic_person"
                app:iconGravity="end"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeMaxTextSize="16sp"
                app:autoSizeStepGranularity="1sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegistroLocal"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/secondary"
                android:text="@string/local"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:icon="@drawable/ic_local"
                app:iconGravity="end"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeMaxTextSize="16sp"
                app:autoSizeStepGranularity="1sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>